# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# VITE_* variables are bundled into the client — these are OK to expose.
# Non-VITE variables (service role key, Resend) MUST stay server-side.

# Supabase (public, client-safe)
VITE_SUPABASE_URL=https://ssnzebudcbrtpiwilroo.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-jwt-from-supabase-dashboard

# App config
VITE_APP_NAME=AWC Group
VITE_SUPPORT_EMAIL=support@awcgroup.uk

# Edge function secrets — set these in Supabase dashboard (Project Settings -> Edge Functions),
# NOT here. Listed for reference only.
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@awcgroup.uk
# APP_URL — used by send-quote / send-invoice to build the public link in
# the email body. Must be the live deploy URL. While AWC is on the
# Cloudflare Pages temp domain, set:
#   APP_URL=https://awcgroup.pages.dev
# After cutting over to the custom domain, change to:
#   APP_URL=https://app.awcgroup.uk
# APP_URL=https://awcgroup.pages.dev
